# ============================================================
# AI Interview Assistant — Production Environment Variables
# Copy to .env.production and fill in real values
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME=AI Interview Assistant
APP_VERSION=2.1.0
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── Domain & SSL ────────────────────────────────────────────
DOMAIN_NAME=interview.yourdomain.com
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ── Backend ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
ALLOWED_ORIGINS=https://interview.yourdomain.com
CORS_ORIGINS=["https://interview.yourdomain.com"]

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=interview
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_HERE
POSTGRES_DB=interview_assistant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# PostgreSQL performance tuning
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_MAX_CONNECTIONS=100

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD_HERE
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_MAX_MEMORY=256mb

# ── AI / NLP Engine ─────────────────────────────────────────
OPENROUTER_API_KEY=CHANGE_ME_YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# ── File Upload ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/app/uploads

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# ── Docker Registry ─────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_PREFIX=your-org/ai-interview
TAG=latest

# ── Monitoring (optional) ───────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# ── Backup (optional) ──────────────────────────────────────
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_SCHEDULE=0 2 * * *
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
