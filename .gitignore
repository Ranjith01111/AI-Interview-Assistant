# ============================================
# AI Interview Assistant — .gitignore
# ============================================

# ── Environment & Secrets ────────────────────
.env
.env.prod
.env.local
*.pem
*.key

# ── Python ───────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ── Node.js ──────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
.vite/

# ── Docker ───────────────────────────────────
certbot/
data/
logs/

# ── IDE ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── FAISS / ML weights ───────────────────────
*.index
backend/static/weights/
backend/static/snapshots/

# ── Logs ─────────────────────────────────────
*.log
logs/
